{
  "name": "HACK",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy --minify",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "build:fe": "npx esbuild src/frontend/app.ts --bundle --outfile=front/js/app.js --format=esm --minify",
    "watch:fe": "npx esbuild src/frontend/app.ts --bundle --outfile=front/js/app.js --format=esm --watch"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "hono": "^4.12.7"
  },
  "devDependencies": {
    "wrangler": "^4.4.0"
  }
}
